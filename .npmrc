# Use hoisted node_modules layout (npm/yarn-classic style).
# Reason: pnpm's default isolated layout creates deeply-nested hash-named paths like
#   node_modules/.pnpm/expo-modules-core@55.0.15_r_62e4b5725de46ad15869e02111966b1a/node_modules/...
# which exceed Windows MAX_PATH (260 chars) during Android NDK/CMake compilation.
# Hoisted layout places packages at node_modules/<pkg> directly, cutting ~60 chars.
node-linker=hoisted
shamefully-hoist=true
